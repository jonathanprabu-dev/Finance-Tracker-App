# Copy this file to ".env" and adjust as needed.

# SQLite database location (relative to the prisma/ directory).
DATABASE_URL="file:./dev.db"

# Stock price provider: "mock" (default, no key required) or "finnhub".
STOCK_PROVIDER="mock"

# Required only when STOCK_PROVIDER="finnhub". Get a free key at https://finnhub.io
FINNHUB_API_KEY=""
